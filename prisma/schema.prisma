// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum ExpenseCategory {
  FOOD
  OFFERINGS_HONORARIUM
  OFFERINGS_BRICK_LAYERS
  OFFERINGS_SUNDAY
  OFFERINGS_TUESDAY
  TRANSPORT
  COMMUNICATION_SMS
  COMMUNICATION_CALLS
  COMMUNICATION_BUNDLES
  TITHES
  OTHER_GIVING_BIRTHDAYS
  OTHER_GIVING_FUNERALS
  OTHER_GIVING_LUNCH
  RENT
  MISCELLANEOUS
}

enum SavingsType {
  EMERGENCY
  SINKING
  LONG_TERM
}

enum IncomeCategory {
  SALARY
  BUSINESS
  FREELANCE
  INVESTMENTS
  GIFTS
  REFUNDS
  SIDE_HUSTLE
  RENTAL
  BONUS
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAWAL
}

enum SubscriptionTier {
  FREE
  BASIC
  MEDIUM
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  TRIAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  GOOGLE_PLAY
  STRIPE
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?   // Hashed password for credentials auth
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  expenses      Expense[]
  incomes       Income[]
  savings       Savings[]
  transactions  Transaction[]
  budgets       Budget[]
  subscription  Subscription?
  payments      Payment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== EMAIL VERIFICATION & PASSWORD RESET ====================

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String   // 6-digit code
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0) // Track failed attempts (max 5)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String   // 6-digit code
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0) // Track failed attempts (max 5)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
  @@map("password_resets")
}

// ==================== ADMIN ====================

enum UserRole {
  USER
  ADMIN
}

model Expense {
  id          String          @id @default(cuid())
  amount      Int             // Store as cents/smallest currency unit for precision
  currency    String          @default("KES") // Kenyan Shillings as default
  category    ExpenseCategory
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([category])
  @@map("expenses")
}

model Income {
  id          String         @id @default(cuid())
  amount      Int            // Store as cents/smallest currency unit for precision
  currency    String         @default("KES")
  category    IncomeCategory
  source      String?        // e.g., "Company Name", "Client Name"
  description String?
  date        DateTime       @default(now())
  isRecurring Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([category])
  @@map("incomes")
}

model Savings {
  id             String      @id @default(cuid())
  name           String      // e.g., "Emergency Fund", "Vacation Fund"
  type           SavingsType
  goalAmount     Int         // Target amount in cents
  amountSaved    Int         @default(0) // Current amount saved in cents
  currency       String      @default("KES")
  startDate      DateTime    @default(now())
  targetDate     DateTime?   // Optional target date to reach goal
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  deposits       SavingsDeposit[]

  @@index([userId, type])
  @@map("savings")
}

model SavingsDeposit {
  id          String   @id @default(cuid())
  amount      Int      // Amount deposited in cents
  currency    String   @default("KES")
  dateSaved   DateTime @default(now())
  note        String?
  createdAt   DateTime @default(now())
  
  savingsId   String
  savings     Savings  @relation(fields: [savingsId], references: [id], onDelete: Cascade)

  @@index([savingsId, dateSaved])
  @@map("savings_deposits")
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Int             // Amount in cents
  currency    String          @default("KES")
  description String?
  category    String?         // Optional category for grouping
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([type])
  @@map("transactions")
}

model Budget {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  amount      Int             // Budget limit in cents
  currency    String          @default("KES")
  month       Int             // 1-12
  year        Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, month, year])
  @@map("budgets")
}

// ==================== SUBSCRIPTION MODELS ====================

model Subscription {
  id                String             @id @default(cuid())
  tier              SubscriptionTier   @default(FREE)
  status            SubscriptionStatus @default(TRIAL)
  priceKES          Int                @default(0)        // Price in KES (50, 100, 200)
  startDate         DateTime           @default(now())
  endDate           DateTime?                              // When the current period ends
  trialEndsAt       DateTime?                              // 7-day free trial
  cancelledAt       DateTime?
  autoRenew         Boolean            @default(true)
  googlePlayToken   String?                                // Google Play purchase token
  mpesaReceiptNumber String?                               // M-Pesa receipt
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(cuid())
  amount            Int                                    // Amount in KES
  currency          String        @default("KES")
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  tier              SubscriptionTier
  transactionRef    String?       @unique                  // M-Pesa or Google Play ref
  mpesaReceiptNumber String?
  phoneNumber       String?                                // For M-Pesa
  description       String?
  metadata          Json?                                  // Extra payment data
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([transactionRef])
  @@map("payments")
}
