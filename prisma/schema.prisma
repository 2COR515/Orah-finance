generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  role          UserRole      @default(USER)
  accounts      Account[]
  budgets       Budget[]
  expenses      Expense[]
  incomes       Income[]
  payments      Payment[]
  savings       Savings[]
  sessions      Session[]
  subscription  Subscription?
  transactions  Transaction[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
  @@map("password_resets")
}

model Expense {
  id          String          @id @default(cuid())
  amount      Int
  currency    String          @default("KES")
  category    ExpenseCategory
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([category])
  @@map("expenses")
}

model Income {
  id          String         @id @default(cuid())
  amount      Int
  currency    String         @default("KES")
  category    IncomeCategory
  source      String?
  description String?
  date        DateTime       @default(now())
  isRecurring Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([category])
  @@map("incomes")
}

model Savings {
  id          String           @id @default(cuid())
  name        String
  type        SavingsType
  goalAmount  Int
  amountSaved Int              @default(0)
  currency    String           @default("KES")
  startDate   DateTime         @default(now())
  targetDate  DateTime?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits    SavingsDeposit[]

  @@index([userId, type])
  @@map("savings")
}

model SavingsDeposit {
  id        String   @id @default(cuid())
  amount    Int
  currency  String   @default("KES")
  dateSaved DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())
  savingsId String
  savings   Savings  @relation(fields: [savingsId], references: [id], onDelete: Cascade)

  @@index([savingsId, dateSaved])
  @@map("savings_deposits")
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Int
  currency    String          @default("KES")
  description String?
  category    String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([type])
  @@map("transactions")
}

model Budget {
  id        String          @id @default(cuid())
  category  ExpenseCategory
  amount    Int
  currency  String          @default("KES")
  month     Int
  year      Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, month, year])
  @@map("budgets")
}

model Subscription {
  id                 String             @id @default(cuid())
  tier               SubscriptionTier   @default(FREE)
  status             SubscriptionStatus @default(TRIAL)
  priceKES           Int                @default(0)
  startDate          DateTime           @default(now())
  endDate            DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  autoRenew          Boolean            @default(true)
  googlePlayToken    String?
  mpesaReceiptNumber String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

model Payment {
  id                 String           @id @default(cuid())
  amount             Int
  currency           String           @default("KES")
  method             PaymentMethod
  status             PaymentStatus    @default(PENDING)
  tier               SubscriptionTier
  transactionRef     String?          @unique
  mpesaReceiptNumber String?
  phoneNumber        String?
  description        String?
  metadata           Json?
  paidAt             DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([transactionRef])
  @@map("payments")
}

enum ExpenseCategory {
  FOOD
  OFFERINGS_HONORARIUM
  OFFERINGS_BRICK_LAYERS
  OFFERINGS_SUNDAY
  OFFERINGS_TUESDAY
  TRANSPORT
  COMMUNICATION_SMS
  COMMUNICATION_CALLS
  COMMUNICATION_BUNDLES
  TITHES
  OTHER_GIVING_BIRTHDAYS
  OTHER_GIVING_FUNERALS
  OTHER_GIVING_LUNCH
  RENT
  MISCELLANEOUS
}

enum SavingsType {
  EMERGENCY
  SINKING
  LONG_TERM
}

enum IncomeCategory {
  SALARY
  BUSINESS
  FREELANCE
  INVESTMENTS
  GIFTS
  REFUNDS
  SIDE_HUSTLE
  RENTAL
  BONUS
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAWAL
}

enum SubscriptionTier {
  FREE
  BASIC
  MEDIUM
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  TRIAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  GOOGLE_PLAY
  STRIPE
}

enum UserRole {
  USER
  ADMIN
}
